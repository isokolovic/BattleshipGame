<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GUI.Views.GridView"
             x:CompileBindings="False">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="24"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="24"/>
			<ColumnDefinition Width="Auto"/>
		</Grid.ColumnDefinitions>

		<!-- Column headers: A-J -->
		<ItemsControl Grid.Row="0" Grid.Column="1"
                      ItemsSource="{Binding ColumnHeaders}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<UniformGrid Rows="1" Columns="10"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<TextBlock Text="{Binding}"
                               Width="38" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="#757575"/>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

		<!-- Row numbers: 1-10 -->
		<ItemsControl Grid.Row="1" Grid.Column="0"
                      ItemsSource="{Binding RowNumbers}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<UniformGrid Rows="10" Columns="1"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<TextBlock Text="{Binding}"
                               Height="38" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="#757575"/>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

		<!-- 10x10 cell grid -->
		<ItemsControl Grid.Row="1" Grid.Column="1"
                      ItemsSource="{Binding Cells}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<UniformGrid Rows="10" Columns="10"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<Border Classes="cell"
                            Classes.clickable="{Binding IsClickable}"
                            Width="36" Height="36"
                            Margin="1" CornerRadius="4"
                            Background="{Binding BackgroundBrush}"
                            PointerPressed="OnCellPointerPressed"/>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

	</Grid>

</UserControl>